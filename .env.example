# Optional API keys
NEWSAPI_KEY=
GEMINI_API_KEY=

# Comma-separated browser origins allowed to call FastAPI
SONAR_CORS_ORIGINS=https://sonar-ai-radar.liyerongvv.chatgpt.site,http://localhost:5173,http://127.0.0.1:5173

# Local PostgreSQL (replace placeholders in your untracked .env)
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://sonar:change-me@localhost:5432/sonar
TEST_DATABASE_URL=postgresql+psycopg://sonar:change-me@localhost:5432/sonar_test

# Hacker News feeds to poll
SONAR_HN_ENDPOINTS=topstories,newstories

# Collector and dashboard settings
SONAR_POLL_INTERVAL_SECONDS=180
SONAR_MONITOR_GAP_THRESHOLD_SECONDS=600
SONAR_ALERT_WINDOW_MINUTES=30

# Anomaly and AI settings
SONAR_ANOMALY_WINDOW=6
SONAR_ZSCORE_THRESHOLD=2.0
SONAR_MONITORING_INTERVAL_SECONDS=1800
SONAR_MONITORING_STORY_SAMPLE_SIZE=8
SONAR_MAX_STORY_IDS=60
GEMINI_MODEL=gemini-3.5-flash-lite
