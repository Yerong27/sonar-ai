FROM python:3.13-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY app.py .
COPY assets ./assets
COPY sonar ./sonar

EXPOSE 8060

CMD ["uvicorn", "sonar.api.main:app", "--host", "0.0.0.0", "--port", "8060"]
